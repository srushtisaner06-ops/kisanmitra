<script src="global.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('fert-search');
  var fertCards = document.querySelectorAll('.fert-card');
  var typeBtns = document.querySelectorAll('.fert-type-btn');
  var activeType = 'all';

  function filterCards() {
    var q = searchInput ? searchInput.value.toLowerCase() : '';
    fertCards.forEach(function(card) {
      var nameMatch = !q || (card.dataset.name || '').includes(q);
      var typeMatch = activeType === 'all' || card.dataset.type === activeType;
      card.style.display = (nameMatch && typeMatch) ? '' : 'none';
    });
  }

  if (searchInput) {
    searchInput.addEventListener('input', filterCards);
    document.querySelector('button.w-full.md\\:w-auto').addEventListener('click', filterCards);
  }

  typeBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      typeBtns.forEach(function(b) {
        b.classList.remove('bg-primary','text-on-primary');
        b.classList.add('bg-surface-container','text-on-surface-variant');
      });
      btn.classList.add('bg-primary','text-on-primary');
      btn.classList.remove('bg-surface-container','text-on-surface-variant');
      activeType = btn.dataset.type;
      filterCards();
    });
  });

  // Dosage Table buttons
  document.querySelectorAll('.fert-card button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var name = this.closest('.fert-card').querySelector('h3').textContent;
      showToast('\uD83D\uDCCA Dosage table for ' + name + ' loaded');
    });
  });

  // PDF download
  var pdfBtn = document.querySelector('[data-icon="download"]');
  if (pdfBtn) pdfBtn.closest('button').addEventListener('click', function(){
    showToast('\uD83D\uDCC4 Crop-wise fertilizer schedule PDF downloading...');
  });

  // Learn Techniques button
  var learnBtn = document.querySelector('.bg-white.text-primary.font-label-md.rounded-full');
  if (learnBtn) learnBtn.addEventListener('click', function(){
    showToast('\uD83C\uDF31 Erosion control techniques guide loading...');
  });
});
</script>
</body></html>